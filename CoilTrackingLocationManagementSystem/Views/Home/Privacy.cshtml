@{
    ViewData["Title"] = "Project Notes";
}

<div class="app-card">
    <h1 class="h3 mb-3">Implementation Notes</h1>
    <p>This starter delivers the first project phase for a coil tracing system using ASP.NET Core MVC with Bootstrap and jQuery on the UI.</p>
    <ul class="mb-0">
        <li>Dashboard for stock and movement visibility</li>
        <li>Master setup for locations, grades, and suppliers</li>
        <li>Transaction page for inward entry and movement tracking</li>
        <li>Reports page for stock summary and audit trail</li>
        <li>MySQL schema script included under the <code>Database</code> folder</li>
    </ul>
</div>
