<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoilTrackingLocationManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CoilTrackingLocationManagementSystem.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    @{
        var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
        var actionName = ViewContext.RouteData.Values["action"]?.ToString();
        var isMastersSection = string.Equals(controllerName, "Masters", StringComparison.OrdinalIgnoreCase);
        var mastersExpandedClass = isMastersSection ? "show" : string.Empty;
        var mastersToggleClass = isMastersSection ? string.Empty : "collapsed";

        string NavClass(string controller, string? action = null)
        {
            var isActiveController = string.Equals(controllerName, controller, StringComparison.OrdinalIgnoreCase);
            var isActiveAction = action is null || string.Equals(actionName, action, StringComparison.OrdinalIgnoreCase);
            return isActiveController && isActiveAction ? "nav-link active" : "nav-link";
        }

        string SubNavClass(string action)
        {
            return isMastersSection && string.Equals(actionName, action, StringComparison.OrdinalIgnoreCase)
                ? "nav-link nav-link-sub active"
                : "nav-link nav-link-sub";
        }
    }
    <div class="shell-layout">
        <aside class="sidebar">
            <div class="sidebar-glow sidebar-glow-top"></div>
            <div class="sidebar-glow sidebar-glow-bottom"></div>
            <a class="brand-block" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">CTMS</span>
                <div>
                    <strong>Coil Tracking</strong>
                    <small>Location Management</small>
                </div>
            </a>

            <nav class="nav flex-column app-nav">
                <div class="nav-section-title">Workspace</div>
                <a class="@NavClass("Home", "Index")" asp-controller="Home" asp-action="Index">Dashboard</a>
                <button class="nav-link nav-link-toggle @mastersToggleClass" type="button" data-bs-toggle="collapse" data-bs-target="#mastersMenu" aria-expanded="@(isMastersSection.ToString().ToLower())" aria-controls="mastersMenu">
                    <span>Masters</span>
                    <span class="nav-caret">▾</span>
                </button>
                <div class="collapse @mastersExpandedClass" id="mastersMenu">
                    <a class="@SubNavClass("Index")" asp-controller="Masters" asp-action="Index">Master Overview</a>
                    <a class="@SubNavClass("Warehouses")" asp-controller="Masters" asp-action="Warehouses">Warehouse Master</a>
                    <a class="@SubNavClass("Bays")" asp-controller="Masters" asp-action="Bays">Bay Master</a>
                    <a class="@SubNavClass("SubBays")" asp-controller="Masters" asp-action="SubBays">SubBay Master</a>
                    <a class="@SubNavClass("Rows")" asp-controller="Masters" asp-action="Rows">Row Master</a>
                </div>
                <div class="nav-section-title">Operations</div>
                <a class="@NavClass("Transactions", "Index")" asp-controller="Transactions" asp-action="Index">Transactions</a>
                <a class="@NavClass("Reports", "Index")" asp-controller="Reports" asp-action="Index">Reports</a>
                <a class="@NavClass("Home", "Privacy")" asp-controller="Home" asp-action="Privacy">Project Notes</a>
            </nav>
        </aside>

        <div class="content-panel">
            @* <header class="topbar">
                <div>
                    <p class="eyebrow mb-1">Coil Tracking Workspace</p>
                    <h1 class="h4 mb-0">@ViewData["Title"]</h1>
                </div>
                <div class="topbar-badge">Warehouse Flow Live</div>
            </header> *@

            <main role="main" class="page-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
