@model MastersViewModel
@{
    ViewData["Title"] = "Warehouse Master";
}

<section class="master-hero mb-4">
    <div>
        <p class="eyebrow mb-2">Master</p>
        <h1 class="h2 mb-2">Warehouse Master</h1>
        <p class="mb-0 text-secondary">Manage top-level warehouse definitions on a dedicated page.</p>
    </div>
    <div class="master-hero-actions">
        <a class="btn btn-outline-light" asp-action="Index">All Masters</a>
        <button class="btn btn-light" type="button" data-bs-toggle="modal" data-bs-target="#warehouseModal">Add Warehouse</button>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-@TempData["StatusType"] mb-4" role="alert">@statusMessage</div>
}

<div class="row g-4">
    <div class="col-xl-8">
        <div class="app-card master-card">
            <div class="section-heading">
                <div>
                    <h2 class="h5 mb-1">Warehouse List</h2>
                    <p class="text-secondary mb-0">One page focused only on warehouse setup.</p>
                </div>
                <div class="master-card-tools">
                    <input type="search" class="form-control form-control-sm table-search master-search" data-target="#warehouseTable" placeholder="Search warehouse..." />
                </div>
            </div>
            <div class="table-responsive">
                <table class="table align-middle master-table" id="warehouseTable" data-page-size="5">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var warehouse in Model.Warehouses)
                    {
                        <tr>
                            <td>@warehouse.Code</td>
                            <td>@warehouse.Name</td>
                            <td>@warehouse.Description</td>
                            <td>@warehouse.CreatedDate.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td class="text-end action-cell">
                                <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#warehouseEditModal-@warehouse.Id">Edit</button>
                                <form asp-action="DeleteWarehouse" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@warehouse.Id" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="table-pager" data-target="#warehouseTable"></div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="metric-card mb-4">
            <span>Total Warehouses</span>
            <strong>@Model.Warehouses.Count</strong>
        </div>
        <div class="app-card">
            <h2 class="h5 mb-3">Next Steps</h2>
            <div class="chip-list">
                <a class="chip text-decoration-none" asp-action="Bays">Open Bay Master</a>
                <a class="chip text-decoration-none" asp-action="SubBays">Open SubBay Master</a>
                <a class="chip text-decoration-none" asp-action="Rows">Open Row Master</a>
            </div>
        </div>
    </div>
</div>

@foreach (var warehouse in Model.Warehouses)
{
    <div class="modal fade" id="warehouseEditModal-@warehouse.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="UpdateWarehouse" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@warehouse.Id" />
                    <div class="modal-header">
                        <h2 class="modal-title fs-5">Edit Warehouse</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Code</label>
                                <input class="form-control" name="Code" value="@warehouse.Code" required />
                            </div>
                            <div class="col-md-8">
                                <label class="form-label">Name</label>
                                <input class="form-control" name="Name" value="@warehouse.Name" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <input class="form-control" name="Description" value="@warehouse.Description" />
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@warehouse.IsActive" />
                                    <label class="form-check-label">Active</label>
                                </div>
                                <input type="hidden" name="IsActive" value="false" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                        <button class="btn btn-primary" type="submit">Update Warehouse</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="warehouseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateWarehouse" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Add Warehouse</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Code</label>
                            <input class="form-control" name="Code" required />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Name</label>
                            <input class="form-control" name="Name" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <input class="form-control" name="Description" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                                <label class="form-check-label">Active</label>
                            </div>
                            <input type="hidden" name="IsActive" value="false" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                    <button class="btn btn-primary" type="submit">Save Warehouse</button>
                </div>
            </form>
        </div>
    </div>
</div>
