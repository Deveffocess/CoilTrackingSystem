@model MastersViewModel
@{
    ViewData["Title"] = "Row Master";
}

<section class="master-hero mb-4">
    <div>
        <p class="eyebrow mb-2">Master</p>
        <h1 class="h2 mb-2">Row Master</h1>
        <p class="mb-0 text-secondary">Manage the final storage rows where coils are physically assigned.</p>
    </div>
    <div class="master-hero-actions">
        <a class="btn btn-outline-light" asp-action="Index">All Masters</a>
        <button class="btn btn-light" type="button" data-bs-toggle="modal" data-bs-target="#rowModal">Add Row</button>
    </div>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-@TempData["StatusType"] mb-4" role="alert">@statusMessage</div>
}

<div class="row g-4">
    <div class="col-xl-8">
        <div class="app-card master-card">
            <div class="section-heading">
                <div>
                    <h2 class="h5 mb-1">Row List</h2>
                    <p class="text-secondary mb-0">Dedicated page for the lowest storage level.</p>
                </div>
                <input type="search" class="form-control form-control-sm table-search master-search" data-target="#rowTable" placeholder="Search row or path..." />
            </div>
            <div class="table-responsive">
                <table class="table align-middle master-table" id="rowTable" data-page-size="5">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Path</th>
                            <th>Capacity</th>
                            <th>Occupied</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var location in Model.Locations)
                    {
                        var selectedSubBay = Model.SubBays.FirstOrDefault(x =>
                            x.Name == location.SubBay &&
                            (Model.Bays.FirstOrDefault(b => b.Code == x.BayCode && b.WarehouseCode == x.WarehouseCode)?.Name ?? string.Empty) == location.Bay &&
                            (Model.Warehouses.FirstOrDefault(w => w.Code == x.WarehouseCode)?.Name ?? string.Empty) == location.Warehouse);
                        <tr>
                            <td>@location.Code</td>
                            <td><span class="hierarchy-pill">@location.HierarchyPath</span></td>
                            <td>@location.Capacity</td>
                            <td>@location.Occupied</td>
                            <td>@location.CreatedDate.ToString("dd-MMM-yyyy HH:mm")</td>
                            <td class="text-end action-cell">
                                <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#rowEditModal-@location.Id">Edit</button>
                                <form asp-action="DeleteRow" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@location.Id" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="table-pager" data-target="#rowTable"></div>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="metric-card mb-4">
            <span>Total Rows</span>
            <strong>@Model.Locations.Count</strong>
        </div>
        <div class="app-card">
            <h2 class="h5 mb-3">Hierarchy Links</h2>
            <div class="chip-list">
                <a class="chip text-decoration-none" asp-action="Warehouses">Warehouse Master</a>
                <a class="chip text-decoration-none" asp-action="Bays">Bay Master</a>
                <a class="chip text-decoration-none" asp-action="SubBays">SubBay Master</a>
            </div>
        </div>
    </div>
</div>

@foreach (var location in Model.Locations)
{
    var selectedSubBay = Model.SubBays.FirstOrDefault(x =>
        x.Name == location.SubBay &&
        (Model.Bays.FirstOrDefault(b => b.Code == x.BayCode && b.WarehouseCode == x.WarehouseCode)?.Name ?? string.Empty) == location.Bay &&
        (Model.Warehouses.FirstOrDefault(w => w.Code == x.WarehouseCode)?.Name ?? string.Empty) == location.Warehouse);

    <div class="modal fade" id="rowEditModal-@location.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="UpdateRow" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@location.Id" />
                    <div class="modal-header">
                        <h2 class="modal-title fs-5">Edit Row</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label">Code</label>
                                <input class="form-control" name="Code" value="@location.Code" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Name</label>
                                <input class="form-control" name="Name" value="@location.Name" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">SubBay</label>
                                <select class="form-select" name="SubBayId" required>
                                    <option value="">Select</option>
                                    @foreach (var subBayOption in Model.SubBays)
                                    {
                                        var bayOption = Model.Bays.FirstOrDefault(x => x.Code == subBayOption.BayCode && x.WarehouseCode == subBayOption.WarehouseCode);
                                        var warehouseOption = Model.Warehouses.FirstOrDefault(x => x.Code == subBayOption.WarehouseCode);
                                        <option value="@subBayOption.Id" selected="@(selectedSubBay?.Id == subBayOption.Id)">@warehouseOption?.Name / @bayOption?.Name / @subBayOption.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Row Label</label>
                                <input class="form-control" name="Row" value="@location.Row" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Capacity</label>
                                <input class="form-control" type="number" min="1" name="Capacity" value="@location.Capacity" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Occupied</label>
                                <input class="form-control" type="number" min="0" name="Occupied" value="@location.Occupied" required />
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked="@location.IsActive" />
                                    <label class="form-check-label">Active</label>
                                </div>
                                <input type="hidden" name="IsActive" value="false" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                        <button class="btn btn-primary" type="submit">Update Row</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="rowModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateRow" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Add Row</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Code</label>
                            <input class="form-control" name="Code" required />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Name</label>
                            <input class="form-control" name="Name" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">SubBay</label>
                            <select class="form-select" name="SubBayId" required>
                                <option value="">Select</option>
                                @foreach (var subBay in Model.SubBays)
                                {
                                    var bay = Model.Bays.FirstOrDefault(x => x.Code == subBay.BayCode && x.WarehouseCode == subBay.WarehouseCode);
                                    var warehouse = Model.Warehouses.FirstOrDefault(x => x.Code == subBay.WarehouseCode);
                                    <option value="@subBay.Id">@warehouse?.Name / @bay?.Name / @subBay.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Row Label</label>
                            <input class="form-control" name="Row" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Capacity</label>
                            <input class="form-control" type="number" min="1" name="Capacity" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Occupied</label>
                            <input class="form-control" type="number" min="0" name="Occupied" value="0" required />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                                <label class="form-check-label">Active</label>
                            </div>
                            <input type="hidden" name="IsActive" value="false" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                    <button class="btn btn-primary" type="submit">Save Row</button>
                </div>
            </form>
        </div>
    </div>
</div>
